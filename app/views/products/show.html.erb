<% content_for :title, "#{@product.meta_title.presence || @product.name} — Bird's Blossoms" %>
<% content_for :meta_description, @product.meta_description.presence || @product.description.truncate(160) %>
<% content_for :canonical_url, product_url(@product) %>

<div class="max-w-5xl mx-auto">
  <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8">
    <%= link_to "Home", root_path, class: "hover:text-rose-600 transition-colors" %>
    <span>/</span>
    <%= link_to "Shop", products_path, class: "hover:text-rose-600 transition-colors" %>
    <% if @product.category %>
      <span>/</span>
      <%= link_to @product.category.name, products_path(category: @product.category.slug), class: "hover:text-rose-600 transition-colors" %>
    <% end %>
    <span>/</span>
    <span class="text-gray-700 font-medium"><%= @product.name %></span>
  </nav>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
    <div>
      <% if @product.product_images.loaded? && @product.product_images.any? %>
        <div class="aspect-square bg-rose-50 rounded-2xl overflow-hidden mb-3">
          <%= image_tag @product.primary_image.image, alt: @product.primary_image.alt_text, class: "w-full h-full object-cover" %>
        </div>
        <% if @product.product_images.size > 1 %>
          <div class="grid grid-cols-4 gap-2">
            <% @product.product_images.each do |img| %>
              <div class="aspect-square bg-rose-50 rounded-lg overflow-hidden">
                <%= image_tag img.image, alt: img.alt_text, class: "w-full h-full object-cover" %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="aspect-square bg-gradient-to-br from-rose-50 to-pink-100 rounded-2xl flex items-center justify-center">
          <span class="text-8xl">🌸</span>
        </div>
      <% end %>
    </div>

    <div>
      <% if @product.category %>
        <span class="text-xs font-semibold text-rose-500 uppercase tracking-wider"><%= @product.category.name %></span>
      <% end %>

      <h1 class="text-3xl font-bold text-gray-900 mt-2 mb-4"><%= @product.name %></h1>

      <div class="flex items-baseline gap-3 mb-6">
        <span class="text-3xl font-bold text-gray-900"><%= @product.price_in_dollars %></span>
        <% if @product.on_sale? %>
          <span class="text-lg text-gray-400 line-through"><%= @product.compare_at_price_in_dollars %></span>
          <span class="text-sm font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">Sale</span>
        <% end %>
      </div>

      <div class="prose prose-sm text-gray-600 mb-8">
        <%= simple_format @product.description %>
      </div>

      <% if @product.sold_out? %>
        <button disabled class="w-full py-4 bg-gray-100 text-gray-400 rounded-xl font-semibold text-lg cursor-not-allowed">
          Out of Stock
        </button>
      <% else %>
        <%= turbo_frame_tag "cart-action-#{@product.id}" do %>
          <%= button_to add_item_cart_path, method: :post,
              params: { product_id: @product.id, quantity: 1 },
              class: "w-full py-4 bg-rose-600 hover:bg-rose-700 text-white rounded-xl font-semibold text-lg transition-colors" do %>
            Add to Cart
          <% end %>
        <% end %>
      <% end %>

      <div class="mt-8 space-y-3">
        <div class="flex items-center gap-3 text-sm text-gray-500">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Fresh for 7+ days guaranteed
        </div>
        <div class="flex items-center gap-3 text-sm text-gray-500">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Same-day delivery available
        </div>
        <div class="flex items-center gap-3 text-sm text-gray-500">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Happiness guarantee
        </div>
      </div>
    </div>
  </div>

  <% if @related_products&.any? %>
    <section class="mt-20">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">You May Also Like</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <% @related_products.each do |product| %>
          <%= render ProductCardComponent.new(product: product) %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
