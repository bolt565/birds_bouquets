<% content_for :title, "Contact Us — Birds Bouquets" %>
<% content_for :meta_description, "Get in touch with Birds Bouquets. We're happy to help with your order, questions, or feedback." %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Contact Us</h1>
  <p class="text-gray-500 mb-8">We'd love to hear from you. Send us a message and we'll respond within 24 hours.</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="md:col-span-2">
      <%= form_with url: contact_path, method: :post, html: { class: "space-y-4" } do |f| %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :name, "Your Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :name, required: true, placeholder: "Jane Smith",
                class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
          </div>
          <div>
            <%= f.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.email_field :email, required: true, placeholder: "jane@example.com",
                class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
          </div>
        </div>

        <div>
          <%= f.label :subject, "Subject", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :subject,
              [["Order Issue", "order_issue"], ["Product Question", "product_question"], ["Delivery Question", "delivery"], ["Other", "other"]],
              {},
              class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
        </div>

        <div>
          <%= f.label :message, "Message", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :message, required: true, rows: 5, placeholder: "How can we help you?",
              class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300 resize-none" %>
        </div>

        <%= f.submit "Send Message", class: "w-full py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors cursor-pointer" %>
      <% end %>
    </div>

    <div class="space-y-5">
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Email</h3>
        <p class="text-sm text-gray-500">hello@birdsbouquets.com</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Hours</h3>
        <p class="text-sm text-gray-500">Mon – Sat: 8am – 6pm</p>
        <p class="text-sm text-gray-500">Sun: 10am – 4pm</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Response Time</h3>
        <p class="text-sm text-gray-500">We reply within 24 hours, often sooner.</p>
      </div>
    </div>
  </div>
</div>
