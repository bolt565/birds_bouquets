<% content_for :title, "Your Cart — Bird's Blossoms" %>

<div class="max-w-4xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Your Cart</h1>

  <% if @items.empty? %>
    <div class="text-center py-20">
      <p class="text-6xl mb-4">🛒</p>
      <h2 class="text-xl font-semibold text-gray-700 mb-2">Your cart is empty</h2>
      <p class="text-gray-400 mb-6">Add some beautiful flowers to get started!</p>
      <%= link_to "Browse Flowers", products_path, class: "inline-flex items-center px-6 py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-4">
        <% @items.each do |item| %>
          <div class="bg-white border border-gray-100 rounded-xl p-4 flex items-center gap-4">
            <div class="w-20 h-20 bg-rose-50 rounded-lg flex-shrink-0 overflow-hidden">
              <% if item[:product].primary_image&.image&.attached? %>
                <%= image_tag item[:product].primary_image.image, class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-3xl">🌸</div>
              <% end %>
            </div>

            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 truncate">
                <%= link_to item[:product].name, product_path(item[:product]), class: "hover:text-rose-600 transition-colors" %>
              </h3>
              <p class="text-sm text-gray-500"><%= format_cents(item[:unit_price_cents]) %> each</p>
            </div>

            <div class="flex items-center gap-3">
              <%= form_with url: update_item_cart_path, method: :patch, data: { turbo: false } do |f| %>
                <%= f.hidden_field :product_id, value: item[:product].id %>
                <div class="flex items-center border border-gray-200 rounded-lg">
                  <button type="submit" name="quantity" value="<%= [item[:quantity] - 1, 0].max %>" class="w-8 h-8 flex items-center justify-center text-gray-600 hover:text-rose-600">−</button>
                  <span class="w-10 text-center text-sm font-medium"><%= item[:quantity] %></span>
                  <button type="submit" name="quantity" value="<%= item[:quantity] + 1 %>" class="w-8 h-8 flex items-center justify-center text-gray-600 hover:text-rose-600">+</button>
                </div>
              <% end %>

              <p class="text-sm font-semibold text-gray-900 w-16 text-right"><%= format_cents(item[:line_total_cents]) %></p>

              <%= button_to remove_item_cart_path, method: :delete, params: { product_id: item[:product].id },
                  class: "text-gray-300 hover:text-red-500 transition-colors" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div>
        <div class="bg-white border border-gray-100 rounded-xl p-6 sticky top-24">
          <h2 class="font-semibold text-gray-900 mb-4">Order Summary</h2>

          <div class="space-y-2 mb-4">
            <div class="flex justify-between text-sm text-gray-600">
              <span>Subtotal (<%= pluralize(@items.sum { |i| i[:quantity] }, "item") %>)</span>
              <span><%= format_cents(@total_cents) %></span>
            </div>
            <div class="flex justify-between text-sm text-gray-600">
              <span>Shipping</span>
              <span class="text-green-600 font-medium">Free</span>
            </div>
          </div>

          <div class="border-t border-gray-100 pt-4 mb-6">
            <div class="flex justify-between font-bold text-gray-900">
              <span>Total</span>
              <span id="cart-total"><%= format_cents(@total_cents) %></span>
            </div>
          </div>

          <%= link_to "Proceed to Checkout", checkout_address_path, class: "block w-full text-center py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors" %>
          <%= link_to "Continue Shopping", products_path, class: "block w-full text-center py-3 text-gray-500 hover:text-gray-700 text-sm mt-2 transition-colors" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
