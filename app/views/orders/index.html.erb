<% content_for :title, "My Orders — Bird's Blossoms" %>

<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">My Orders</h1>

  <% if @orders.any? %>
    <div class="space-y-4">
      <% @orders.each do |order| %>
        <div class="bg-white border border-gray-100 rounded-xl p-5 hover:border-rose-200 transition-colors">
          <div class="flex items-center justify-between mb-3">
            <div>
              <p class="font-semibold text-gray-900"><%= order.order_number %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= order.created_at.strftime("%B %d, %Y") %></p>
            </div>
            <div class="flex items-center gap-4">
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold <%= order_status_color(order.status) %>">
                <%= order.status.humanize %>
              </span>
              <%= link_to "View", order_path(order), class: "text-rose-600 hover:text-rose-700 text-sm font-medium" %>
            </div>
          </div>
          <div class="flex items-center justify-between text-sm text-gray-500">
            <span><%= pluralize(order.order_items.size, "item") %></span>
            <span class="font-semibold text-gray-900"><%= format_cents(order.total_cents) %></span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20">
      <p class="text-5xl mb-4">📦</p>
      <h2 class="text-lg font-semibold text-gray-700 mb-2">No orders yet</h2>
      <p class="text-gray-400 mb-6">Once you place an order, it'll show up here.</p>
      <%= link_to "Shop Now", products_path, class: "inline-flex items-center px-6 py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors" %>
    </div>
  <% end %>
</div>
