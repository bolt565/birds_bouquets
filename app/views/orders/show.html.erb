<% content_for :title, "Order #{@order.order_number} — Birds Bouquets" %>

<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Order <%= @order.order_number %></h1>
      <p class="text-sm text-gray-400 mt-1">Placed on <%= @order.created_at.strftime("%B %d, %Y") %></p>
    </div>
    <span class="px-3 py-1.5 rounded-full text-sm font-semibold <%= order_status_color(@order.status) %>">
      <%= @order.status.humanize %>
    </span>
  </div>

  <%= render OrderStatusTimelineComponent.new(order: @order) %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
    <div class="bg-white border border-gray-100 rounded-xl p-6">
      <h2 class="font-semibold text-gray-900 mb-4">Items Ordered</h2>
      <div class="space-y-3">
        <% @order.order_items.each do |item| %>
          <div class="flex items-center gap-3 py-2 border-b border-gray-50 last:border-0">
            <div class="w-10 h-10 bg-rose-50 rounded-lg text-center text-lg leading-10 flex-shrink-0">🌸</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-900"><%= item.product_name %></p>
              <p class="text-xs text-gray-400">Qty: <%= item.quantity %> &times; <%= format_cents(item.unit_price_cents) %></p>
            </div>
            <p class="text-sm font-semibold"><%= format_cents(item.line_total_cents) %></p>
          </div>
        <% end %>
      </div>
      <div class="border-t border-gray-100 pt-4 mt-2 space-y-1">
        <div class="flex justify-between text-sm text-gray-500">
          <span>Subtotal</span><span><%= format_cents(@order.subtotal_cents) %></span>
        </div>
        <div class="flex justify-between text-sm text-gray-500">
          <span>Shipping</span><span class="text-green-600">Free</span>
        </div>
        <div class="flex justify-between font-bold text-gray-900">
          <span>Total</span><span><%= format_cents(@order.total_cents) %></span>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-white border border-gray-100 rounded-xl p-6">
        <h2 class="font-semibold text-gray-900 mb-3">Delivery Address</h2>
        <p class="text-sm text-gray-600"><%= @order.shipping_name %></p>
        <p class="text-sm text-gray-600"><%= @order.shipping_line1 %><%= ", #{@order.shipping_line2}" if @order.shipping_line2.present? %></p>
        <p class="text-sm text-gray-600"><%= @order.shipping_city %>, <%= @order.shipping_state %> <%= @order.shipping_zip %></p>
      </div>

      <% if @order.tracking_number.present? %>
        <div class="bg-blue-50 border border-blue-100 rounded-xl p-6">
          <h2 class="font-semibold text-gray-900 mb-2">Tracking</h2>
          <p class="text-sm font-mono text-blue-700 font-semibold"><%= @order.tracking_number %></p>
          <% if @order.shipped_at %>
            <p class="text-xs text-gray-400 mt-1">Shipped <%= @order.shipped_at.strftime("%B %d, %Y") %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-8 text-center">
    <%= link_to "← Back to Orders", orders_path, class: "text-rose-600 hover:underline text-sm" if user_signed_in? %>
  </div>
</div>
