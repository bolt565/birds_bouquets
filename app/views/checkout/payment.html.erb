<% content_for :title, "Payment — Birds Bouquets" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <div class="flex items-center gap-4 text-sm">
      <span class="flex items-center gap-2 text-gray-400">
        <span class="w-6 h-6 bg-green-500 text-white rounded-full flex items-center justify-center text-xs">✓</span>
        Address
      </span>
      <div class="flex-1 h-px bg-rose-300"></div>
      <span class="flex items-center gap-2 font-semibold text-rose-600">
        <span class="w-6 h-6 bg-rose-600 text-white rounded-full flex items-center justify-center text-xs font-bold">2</span>
        Payment
      </span>
      <div class="flex-1 h-px bg-gray-200"></div>
      <span class="flex items-center gap-2 text-gray-400">
        <span class="w-6 h-6 bg-gray-200 text-gray-500 rounded-full flex items-center justify-center text-xs">3</span>
        Confirm
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
    <div class="md:col-span-3">
      <h1 class="text-2xl font-bold text-gray-900 mb-6">Payment</h1>

      <div class="bg-gray-50 border border-gray-100 rounded-xl p-4 mb-6 text-sm text-gray-600">
        <p class="font-medium text-gray-800 mb-1">Delivering to:</p>
        <p><%= @address["name"] %></p>
        <p><%= @address["line1"] %><%= ", #{@address["line2"]}" if @address["line2"].present? %></p>
        <p><%= @address["city"] %>, <%= @address["state"] %> <%= @address["zip"] %></p>
        <%= link_to "Change", checkout_address_path, class: "text-rose-600 hover:underline text-xs mt-1 inline-block" %>
      </div>

      <form id="payment-form"
            data-controller="stripe-payment"
            data-stripe-payment-client-secret-value="<%= @client_secret %>"
            data-stripe-payment-confirm-url-value="<%= checkout_confirm_path %>"
            data-stripe-payment-publishable-key-value="<%= ENV.fetch("STRIPE_PUBLISHABLE_KEY", "") %>">

        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

        <% unless user_signed_in? %>
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Email for order confirmation</label>
            <input type="email" name="email" required placeholder="your@email.com"
                   class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300">
          </div>
        <% end %>

        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">Card Details</label>
          <div id="card-element" class="p-4 border border-gray-200 rounded-xl bg-white min-h-[52px]"></div>
          <div id="card-error" class="hidden text-red-600 text-sm mt-2"></div>
        </div>

        <button id="submit-btn" type="submit"
                class="w-full py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2">
          <span id="btn-text">Pay <%= format_cents(@total_cents) %></span>
          <span id="btn-loading" class="hidden">
            <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            Processing...
          </span>
        </button>

        <p class="text-xs text-gray-400 text-center mt-3">
          Secured by Stripe. We never store your card details.
        </p>
      </form>
    </div>

    <div class="md:col-span-2">
      <div class="bg-white border border-gray-100 rounded-xl p-5 sticky top-24">
        <h2 class="font-semibold text-gray-900 mb-4">Order Summary</h2>
        <div class="space-y-3 mb-4">
          <% @items.each do |item| %>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-rose-50 rounded-lg flex-shrink-0 text-center text-lg leading-10">🌸</div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-medium text-gray-900 truncate"><%= item[:product].name %></p>
                <p class="text-xs text-gray-400">Qty: <%= item[:quantity] %></p>
              </div>
              <p class="text-xs font-semibold text-gray-900"><%= format_cents(item[:line_total_cents]) %></p>
            </div>
          <% end %>
        </div>
        <div class="border-t border-gray-100 pt-3 space-y-1">
          <div class="flex justify-between text-xs text-gray-500">
            <span>Subtotal</span><span><%= format_cents(@subtotal_cents) %></span>
          </div>
          <div class="flex justify-between text-xs text-gray-500">
            <span>Shipping</span><span class="text-green-600 font-medium">Free</span>
          </div>
          <div class="flex justify-between font-bold text-gray-900 pt-1">
            <span>Total</span><span><%= format_cents(@total_cents) %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
