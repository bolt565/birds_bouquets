<footer class="bg-moss text-cream/80 mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div>
        <%= render "shared/sprig", classes: "w-12 h-8 text-cream/60 mb-3" %>
        <h3 class="font-display text-2xl font-medium uppercase tracking-[0.15em] text-cream mb-3">Bird's Blossoms</h3>
        <p class="text-sm leading-relaxed">Fresh flower delivery to your door. Locally sourced, carefully arranged, joyfully delivered.</p>
      </div>

      <div>
        <h4 class="font-display text-xl text-cream mb-4">shop</h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to "All Flowers", products_path, class: "hover:text-cream transition-colors" %></li>
          <li><%= link_to "About Us", about_path, class: "hover:text-cream transition-colors" %></li>
          <li><%= link_to "Blog", blog_path, class: "hover:text-cream transition-colors" %></li>
          <li><%= link_to "FAQ", faq_path, class: "hover:text-cream transition-colors" %></li>
        </ul>
      </div>

      <div>
        <h4 class="font-display text-xl text-cream mb-4">support</h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to "Contact Us", contact_path, class: "hover:text-cream transition-colors" %></li>
          <li><%= link_to "Returns Policy", returns_path, class: "hover:text-cream transition-colors" %></li>
          <li><%= link_to "Track Order", orders_lookup_path, class: "hover:text-cream transition-colors" %></li>
        </ul>
      </div>

      <div>
        <h4 class="font-display text-xl text-cream mb-4">legal</h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to "Privacy Policy", privacy_path, class: "hover:text-cream transition-colors" %></li>
          <li><%= link_to "Terms of Service", terms_path, class: "hover:text-cream transition-colors" %></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-cream/15 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-cream/60">&copy; <%= Time.current.year %> Bird's Blossoms. All rights reserved.</p>
      <p class="text-cream/60 font-display italic text-sm">flowers that speak for you</p>
    </div>
  </div>
</footer>
