<nav class="bg-cream/90 backdrop-blur border-b border-linen sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 gap-4">
      <a href="<%= root_path %>" class="shrink-0 font-display text-lg sm:text-2xl font-medium uppercase tracking-[0.12em] sm:tracking-[0.18em] text-moss leading-none">
        Bird's Blossoms
      </a>

      <div class="hidden md:flex items-center gap-8">
        <%= link_to "Shop", products_path, class: "text-xs uppercase tracking-[0.18em] text-ink hover:text-sage-deep transition-colors" %>
        <%= link_to "About", about_path, class: "text-xs uppercase tracking-[0.18em] text-ink hover:text-sage-deep transition-colors" %>
        <%= link_to "Blog", blog_path, class: "text-xs uppercase tracking-[0.18em] text-ink hover:text-sage-deep transition-colors" %>
        <%= link_to "FAQ", faq_path, class: "text-xs uppercase tracking-[0.18em] text-ink hover:text-sage-deep transition-colors" %>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to cart_path, class: "relative p-2 text-moss hover:text-sage-deep transition-colors", "aria-label": "Cart" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-10H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <% if cart_count > 0 %>
            <span class="absolute -top-0.5 -right-0.5 w-5 h-5 bg-blush-deep text-ink text-xs rounded-full flex items-center justify-center font-medium">
              <%= cart_count %>
            </span>
          <% end %>
        <% end %>

        <% if user_signed_in? %>
          <%= link_to "Account", account_root_path, class: "text-xs uppercase tracking-[0.18em] text-ink hover:text-sage-deep transition-colors" %>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_root_path, class: "text-xs uppercase tracking-[0.15em] text-cream bg-ink hover:bg-moss px-4 py-2 rounded-full transition-colors" %>
          <% end %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "hidden sm:inline text-xs uppercase tracking-[0.18em] text-ink hover:text-sage-deep transition-colors" %>
          <%= link_to "Sign Up", new_user_registration_path, class: "text-xs uppercase tracking-[0.15em] text-cream bg-moss hover:bg-sage-deep px-4 sm:px-5 py-2.5 rounded-full transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
