<nav class="bg-white border-b border-gray-100 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="<%= root_path %>" class="text-2xl font-bold text-rose-600 tracking-tight">Birds Bouquets & Botanicals</a>

      <div class="hidden md:flex items-center gap-6">
        <%= link_to "Shop", products_path, class: "text-gray-700 hover:text-rose-600 text-sm font-medium transition-colors" %>
        <%= link_to "About", about_path, class: "text-gray-700 hover:text-rose-600 text-sm font-medium transition-colors" %>
        <%= link_to "Blog", blog_path, class: "text-gray-700 hover:text-rose-600 text-sm font-medium transition-colors" %>
        <%= link_to "FAQ", faq_path, class: "text-gray-700 hover:text-rose-600 text-sm font-medium transition-colors" %>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to cart_path, class: "relative p-2 text-gray-600 hover:text-rose-600 transition-colors" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-10H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <% if cart_count > 0 %>
            <span class="absolute -top-1 -right-1 w-5 h-5 bg-rose-600 text-white text-xs rounded-full flex items-center justify-center font-bold">
              <%= cart_count %>
            </span>
          <% end %>
        <% end %>

        <% if user_signed_in? %>
          <%= link_to "Account", account_root_path, class: "text-sm text-gray-700 hover:text-rose-600 font-medium transition-colors" %>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_root_path, class: "text-sm text-white bg-gray-800 hover:bg-gray-900 px-3 py-1.5 rounded-lg font-medium transition-colors" %>
          <% end %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "text-sm text-gray-700 hover:text-rose-600 font-medium transition-colors" %>
          <%= link_to "Sign Up", new_user_registration_path, class: "text-sm text-white bg-rose-600 hover:bg-rose-700 px-4 py-2 rounded-lg font-medium transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
