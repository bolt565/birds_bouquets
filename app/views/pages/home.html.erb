<% content_for :title, "Fresh Flower Delivery | Bird's Blossoms" %>
<% content_for :meta_description, "Beautiful fresh flowers delivered to your door. Shop bouquets, arrangements, and seasonal blooms from Bird's Blossoms." %>

<section class="relative overflow-hidden rounded-[2.5rem] bg-sage px-6 py-12 sm:px-12 lg:px-16 lg:py-16">
  <div class="absolute -bottom-10 -right-6 text-cream/25 -rotate-180 pointer-events-none" aria-hidden="true">
    <%= render "shared/sprig", classes: "w-64 h-44" %>
  </div>

  <div class="relative grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="text-center">
      <%= render "shared/sprig", classes: "w-16 h-10 text-cream/80 mx-auto mb-4" %>
      <h1 class="font-display font-medium uppercase tracking-[0.16em] sm:tracking-[0.22em] text-cream text-3xl sm:text-5xl lg:text-6xl">
        Bird's Blossoms
      </h1>
      <p class="font-display text-cream/90 text-xl sm:text-2xl mt-3">flower studio</p>
      <p class="text-cream/90 text-xs sm:text-base uppercase tracking-[0.2em] sm:tracking-[0.25em] mt-6">
        flowers that speak for you
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 mt-9">
        <%= link_to products_path, class: "bg-blush text-ink text-sm px-6 py-3 rounded-full hover:bg-shell transition-colors" do %>
          Shop bouquets <span aria-hidden="true">&rarr;</span>
        <% end %>
        <span class="bg-shell text-ink text-sm px-6 py-3 rounded-full">Fresh stems daily</span>
        <span class="bg-sage-pale text-ink text-sm px-6 py-3 rounded-full">Local delivery</span>
      </div>
    </div>

    <div class="mx-auto w-52 sm:w-64 lg:w-72">
      <div class="rounded-t-full rounded-b-[2rem] bg-shell px-5 pb-6 pt-14 shadow-sm">
        <%= image_tag "flower-demo.png", alt: "Hand-tied bouquet of pink lilies, roses, and white daisies in a glass vase", class: "w-full" %>
      </div>
    </div>
  </div>
</section>

<section class="mt-16" aria-label="Explore">
  <ul class="flex flex-wrap items-start justify-center gap-8 sm:gap-12">
    <li>
      <%= link_to products_path, class: "group flex flex-col items-center gap-3" do %>
        <span class="w-24 h-24 sm:w-28 sm:h-28 rounded-full border border-sage/70 bg-shell overflow-hidden flex items-center justify-center transition group-hover:border-sage-deep">
          <%= image_tag "flower-demo.png", alt: "", class: "w-full h-full object-cover object-top scale-125", loading: "lazy" %>
        </span>
        <span class="font-display text-lg text-ink group-hover:text-sage-deep transition-colors">our bouquets</span>
      <% end %>
    </li>
    <li>
      <%= link_to about_path, class: "group flex flex-col items-center gap-3" do %>
        <span class="w-24 h-24 sm:w-28 sm:h-28 rounded-full border border-sage/70 bg-blush/60 flex items-center justify-center transition group-hover:border-sage-deep">
          <%= render "shared/sprig", classes: "w-12 h-8 text-moss" %>
        </span>
        <span class="font-display text-lg text-ink group-hover:text-sage-deep transition-colors">about us</span>
      <% end %>
    </li>
    <li>
      <%= link_to blog_path, class: "group flex flex-col items-center gap-3" do %>
        <span class="w-24 h-24 sm:w-28 sm:h-28 rounded-full border border-sage/70 bg-linen flex items-center justify-center transition group-hover:border-sage-deep">
          <svg class="w-10 h-10 text-moss" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 4h11a3 3 0 0 1 3 3v13H8a3 3 0 0 1-3-3V4Z"/>
            <path d="M9 9h6M9 13h6"/>
          </svg>
        </span>
        <span class="font-display text-lg text-ink group-hover:text-sage-deep transition-colors">journal</span>
      <% end %>
    </li>
    <li>
      <%= link_to faq_path, class: "group flex flex-col items-center gap-3" do %>
        <span class="w-24 h-24 sm:w-28 sm:h-28 rounded-full border border-sage/70 bg-shell flex items-center justify-center transition group-hover:border-sage-deep">
          <svg class="w-10 h-10 text-moss" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 20.5s-7.5-4.6-7.5-10A4.3 4.3 0 0 1 12 7.6a4.3 4.3 0 0 1 7.5 2.9c0 5.4-7.5 10-7.5 10Z"/>
          </svg>
        </span>
        <span class="font-display text-lg text-ink group-hover:text-sage-deep transition-colors">flower care</span>
      <% end %>
    </li>
    <li>
      <%= link_to contact_path, class: "group flex flex-col items-center gap-3" do %>
        <span class="w-24 h-24 sm:w-28 sm:h-28 rounded-full border border-sage/70 bg-sage-pale/60 flex items-center justify-center transition group-hover:border-sage-deep">
          <svg class="w-10 h-10 text-moss" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3.5" y="6" width="17" height="13" rx="2.5"/>
            <path d="m4.5 7.5 7.5 6 7.5-6"/>
          </svg>
        </span>
        <span class="font-display text-lg text-ink group-hover:text-sage-deep transition-colors">contact</span>
      <% end %>
    </li>
  </ul>
</section>

<% unless @categories.empty? %>
  <section class="mt-20">
    <p class="text-xs uppercase tracking-[0.3em] text-sage-deep text-center">from the studio</p>
    <h2 class="font-display text-3xl sm:text-4xl text-ink text-center mt-2 mb-8">shop by category</h2>
    <div class="flex flex-wrap justify-center gap-4 sm:gap-5">
      <% tile_tints = %w[bg-sage-pale bg-blush bg-linen bg-shell] %>
      <% @categories.each_with_index do |category, i| %>
        <%= link_to products_path(category: category.slug),
              class: "group flex flex-col justify-between aspect-[4/3] w-[calc(50%-0.5rem)] sm:w-60 lg:w-64 rounded-[1.75rem] p-6 #{tile_tints[i % tile_tints.size]} ring-1 ring-transparent hover:ring-sage-deep/40 transition" do %>
          <%= render "shared/sprig", classes: "w-10 h-7 text-ink/40" %>
          <p class="font-display text-2xl text-ink leading-tight">
            <%= category.name.downcase %>
            <span class="block text-sm font-sans text-ink-soft mt-1 group-hover:text-sage-deep transition-colors">browse <span aria-hidden="true">&rarr;</span></span>
          </p>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<section class="mt-20">
  <div class="flex items-end justify-between gap-4 mb-8">
    <div>
      <p class="text-xs uppercase tracking-[0.3em] text-sage-deep">fresh this week</p>
      <h2 class="font-display text-3xl sm:text-4xl text-ink mt-2">featured bouquets</h2>
    </div>
    <%= link_to "View all", products_path, class: "shrink-0 text-sm text-ink border border-sage rounded-full px-5 py-2 hover:bg-sage-pale/50 hover:border-sage-deep transition-colors" %>
  </div>

  <% if @featured_products.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @featured_products.each do |product| %>
        <%= render ProductCardComponent.new(product: product) %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 rounded-[2rem] bg-linen">
      <%= render "shared/sprig", classes: "w-14 h-9 text-sage-deep mx-auto mb-4" %>
      <p class="font-display text-2xl text-ink">The studio is being restocked</p>
      <p class="text-ink-soft text-sm mt-2">New bouquets arrive soon — check back in a day or two.</p>
      <%= link_to "Contact us", contact_path, class: "mt-5 inline-block text-sm text-cream bg-moss hover:bg-sage-deep px-6 py-2.5 rounded-full transition-colors" %>
    </div>
  <% end %>
</section>

<section class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-5">
  <div class="rounded-[2rem] bg-linen p-8">
    <svg class="w-12 h-12 text-moss" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M3 16V7.5A1.5 1.5 0 0 1 4.5 6H14v10"/>
      <path d="M14 9h3.6a1 1 0 0 1 .9.55L20.7 14a1 1 0 0 1 .1.45V16h-2"/>
      <circle cx="7.5" cy="17.5" r="1.8"/>
      <circle cx="16.5" cy="17.5" r="1.8"/>
      <path d="M9.3 17.5h5.4M3 16h2.7"/>
    </svg>
    <h3 class="font-display text-2xl text-ink mt-5">same-day delivery</h3>
    <p class="text-sm text-ink-soft leading-relaxed mt-2">Order by noon and your flowers arrive today. Next-day delivery available everywhere else.</p>
  </div>

  <div class="rounded-[2rem] bg-blush p-8">
    <svg class="w-12 h-12 text-moss" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 21V9"/>
      <path d="M12 13c-4.5-.5-7-3-7.5-7.5C9 6 11.5 8.5 12 13Z"/>
      <path d="M12 9c.4-3.5 2.4-5.5 6-6-.5 3.6-2.5 5.6-6 6Z"/>
    </svg>
    <h3 class="font-display text-2xl text-ink mt-5">farm fresh</h3>
    <p class="text-sm text-ink-soft leading-relaxed mt-2">Stems sourced daily from local growers and guaranteed fresh for seven days or more.</p>
  </div>

  <div class="rounded-[2rem] bg-sage-pale p-8">
    <svg class="w-12 h-12 text-moss" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 20.5s-7.5-4.6-7.5-10A4.3 4.3 0 0 1 12 7.6a4.3 4.3 0 0 1 7.5 2.9c0 5.4-7.5 10-7.5 10Z"/>
    </svg>
    <h3 class="font-display text-2xl text-ink mt-5">happiness guaranteed</h3>
    <p class="text-sm text-ink-soft leading-relaxed mt-2">Not delighted? Tell us within 24 hours and we'll make it right — no questions asked.</p>
  </div>
</section>
