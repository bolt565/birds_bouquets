<%= form_with model: [:admin, product], html: { class: "space-y-5", enctype: "multipart/form-data" } do |f| %>
  <% if product.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= f.label :name, "Product Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
    <div>
      <%= f.label :slug, "URL Slug", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :slug, placeholder: "auto-generated-from-name", class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
  </div>

  <div>
    <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, required: true, rows: 4, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300 resize-none" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    <div>
      <%= f.label :price_dollars, "Price ($)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :price_dollars, value: product.persisted? ? product.price_cents / 100.0 : nil,
          step: "0.01", min: "0", required: true, placeholder: "29.99",
          class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
    <div>
      <%= f.label :compare_at_price_dollars, "Compare At Price ($)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :compare_at_price_dollars, value: product.persisted? && product.compare_at_price_cents ? product.compare_at_price_cents / 100.0 : nil,
          step: "0.01", min: "0", placeholder: "Optional (for sale badge)",
          class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
    <div>
      <%= f.label :category_id, "Category", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :category_id,
          [["No Category", ""]] + @categories.map { |c| [c.name, c.id] },
          { selected: product.category_id },
          class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
  </div>

  <div class="flex gap-6">
    <label class="flex items-center gap-2 text-sm cursor-pointer">
      <%= f.check_box :in_stock, class: "text-rose-600 focus:ring-rose-300 rounded" %>
      In Stock
    </label>
    <label class="flex items-center gap-2 text-sm cursor-pointer">
      <%= f.check_box :featured, class: "text-rose-600 focus:ring-rose-300 rounded" %>
      Featured on Homepage
    </label>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Product Images</label>
    <input type="file" name="product_images[]" multiple accept="image/*"
           class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-rose-50 file:text-rose-700 hover:file:bg-rose-100 cursor-pointer">
    <% if product.persisted? && product.product_images.any? %>
      <div class="flex gap-2 mt-3 flex-wrap">
        <% product.product_images.each do |img| %>
          <div class="w-16 h-16 bg-gray-100 rounded-lg overflow-hidden">
            <%= image_tag img.image if img.image.attached? %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <details class="border border-gray-200 rounded-xl">
    <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-gray-700">SEO Settings</summary>
    <div class="p-4 space-y-4 border-t border-gray-100">
      <div>
        <%= f.label :meta_title, "Meta Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :meta_title, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
      </div>
      <div>
        <%= f.label :meta_description, "Meta Description", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :meta_description, rows: 2, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300 resize-none" %>
      </div>
    </div>
  </details>

  <div class="flex gap-3 pt-2">
    <%= f.submit product.persisted? ? "Update Product" : "Create Product",
        class: "px-6 py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_products_path, class: "px-6 py-3 border border-gray-200 text-gray-600 rounded-xl font-semibold hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
