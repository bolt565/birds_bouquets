<% content_for :title, "Products — Admin" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Products</h1>
  <%= link_to "Add Product", new_admin_product_path, class: "inline-flex items-center px-4 py-2 bg-rose-600 text-white rounded-lg text-sm font-semibold hover:bg-rose-700 transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 mb-4 p-4">
  <%= form_with url: admin_products_path, method: :get, data: { turbo: false } do |f| %>
    <div class="flex gap-3">
      <%= f.text_field :search, value: params[:search], placeholder: "Search products...",
          class: "flex-1 border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
      <%= f.select :category, [["All Categories", ""]] + @categories.map { |c| [c.name, c.slug] },
          { selected: params[:category] },
          class: "border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
      <%= f.submit "Filter", class: "px-4 py-2 bg-gray-700 text-white text-sm rounded-lg hover:bg-gray-800 cursor-pointer" %>
      <% if params[:search].present? || params[:category].present? %>
        <%= link_to "Clear", admin_products_path, class: "px-4 py-2 border border-gray-200 text-gray-500 text-sm rounded-lg hover:bg-gray-50" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Product</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Price</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @products.any? %>
        <% @products.each do |product| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-rose-50 rounded-lg text-center text-lg leading-10 flex-shrink-0">🌸</div>
                <div>
                  <p class="font-medium text-gray-900"><%= product.name %></p>
                  <p class="text-xs text-gray-400">/products/<%= product.slug %></p>
                </div>
              </div>
            </td>
            <td class="px-5 py-3 text-gray-500"><%= product.category&.name || "—" %></td>
            <td class="px-5 py-3">
              <p class="font-medium text-gray-900"><%= product.price_in_dollars %></p>
              <% if product.on_sale? %>
                <p class="text-xs text-green-600">Sale: <%= product.compare_at_price_in_dollars %></p>
              <% end %>
            </td>
            <td class="px-5 py-3">
              <div class="flex flex-col gap-1">
                <span class="inline-flex items-center text-xs px-2 py-0.5 rounded-full font-medium w-fit <%= product.in_stock? ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' %>">
                  <%= product.in_stock? ? "In Stock" : "Out of Stock" %>
                </span>
                <% if product.featured? %>
                  <span class="inline-flex items-center text-xs px-2 py-0.5 rounded-full font-medium w-fit bg-yellow-50 text-yellow-700">Featured</span>
                <% end %>
              </div>
            </td>
            <td class="px-5 py-3">
              <div class="flex items-center gap-2">
                <%= link_to "Edit", edit_admin_product_path(product), class: "text-xs text-blue-600 hover:underline" %>
                <%= button_to product.in_stock? ? "Mark OOS" : "Mark In Stock", toggle_in_stock_admin_product_path(product), method: :patch,
                    class: "text-xs text-gray-500 hover:text-rose-600 border border-gray-200 px-2 py-1 rounded-lg" %>
                <%= button_to "Delete", admin_product_path(product), method: :delete,
                    data: { turbo_confirm: "Delete '#{product.name}'? This cannot be undone." },
                    class: "text-xs text-red-400 hover:text-red-600 border border-red-100 px-2 py-1 rounded-lg" %>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="5" class="px-5 py-12 text-center text-gray-400">
            No products found. <%= link_to "Add one", new_admin_product_path, class: "text-rose-600 hover:underline" %>.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
