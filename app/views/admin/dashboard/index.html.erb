<% content_for :title, "Admin Dashboard — Bird's Blossoms" %>

<h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Today's Revenue</p>
    <p class="text-2xl font-bold text-gray-900"><%= format_cents(@today_revenue) %></p>
    <p class="text-xs text-gray-400 mt-1"><%= @today_order_count %> orders</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Pending Orders</p>
    <p class="text-2xl font-bold text-gray-900"><%= @pending_orders %></p>
    <p class="text-xs text-gray-400 mt-1">Need attention</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Out of Stock</p>
    <p class="text-2xl font-bold <%= @out_of_stock_count > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= @out_of_stock_count %></p>
    <p class="text-xs text-gray-400 mt-1">Products</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">New Customers</p>
    <p class="text-2xl font-bold text-gray-900"><%= @new_customers_this_week %></p>
    <p class="text-xs text-gray-400 mt-1">This week</p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="font-semibold text-gray-900 mb-4">Revenue (Last 7 Days)</h2>
    <div class="space-y-3">
      <% max_rev = @last_7_days_revenue.map { |d| d[:revenue_cents] }.max.to_f %>
      <% max_rev = 1 if max_rev == 0 %>
      <% @last_7_days_revenue.each do |day| %>
        <div class="flex items-center gap-3">
          <span class="text-xs text-gray-400 w-16 flex-shrink-0"><%= day[:date] %></span>
          <div class="flex-1 bg-gray-100 rounded-full h-4 overflow-hidden">
            <div class="bg-rose-400 h-full rounded-full transition-all" style="width: <%= [(day[:revenue_cents].to_f / max_rev * 100).round, 1].max %>%"></div>
          </div>
          <span class="text-xs font-semibold text-gray-700 w-16 text-right"><%= format_cents(day[:revenue_cents]) %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-semibold text-gray-900">Recent Orders</h2>
      <%= link_to "View All", admin_orders_path, class: "text-xs text-rose-600 hover:underline" %>
    </div>
    <div class="space-y-3">
      <% @recent_orders.each do |order| %>
        <div class="flex items-center justify-between text-sm">
          <div>
            <%= link_to order.order_number, admin_order_path(order), class: "font-medium text-gray-900 hover:text-rose-600 text-xs" %>
            <p class="text-xs text-gray-400 truncate max-w-28"><%= order.email %></p>
          </div>
          <div class="text-right">
            <p class="text-xs font-semibold text-gray-900"><%= format_cents(order.total_cents) %></p>
            <span class="text-xs px-1.5 py-0.5 rounded-full <%= order_status_color(order.status) %>"><%= order.status %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
