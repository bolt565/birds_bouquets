<% content_for :title, "Blog Posts — Admin" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Blog Posts</h1>
  <%= link_to "New Post", new_admin_blog_post_path, class: "inline-flex items-center px-4 py-2 bg-rose-600 text-white rounded-lg text-sm font-semibold hover:bg-rose-700 transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Title</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Published</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3">
              <p class="font-medium text-gray-900"><%= post.title %></p>
              <p class="text-xs text-gray-400 font-mono">/blog/<%= post.slug %></p>
            </td>
            <td class="px-5 py-3">
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold <%= post.status == 'published' ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                <%= post.status.humanize %>
              </span>
            </td>
            <td class="px-5 py-3 text-gray-400 text-xs"><%= post.published_at&.strftime("%b %d, %Y") || "—" %></td>
            <td class="px-5 py-3">
              <div class="flex items-center gap-3">
                <%= link_to "Edit", edit_admin_blog_post_path(post), class: "text-xs text-blue-600 hover:underline" %>
                <% if post.status == "draft" %>
                  <%= button_to "Publish", publish_admin_blog_post_path(post), method: :patch,
                      class: "text-xs text-green-600 border border-green-200 px-2 py-1 rounded-lg hover:bg-green-50" %>
                <% else %>
                  <%= button_to "Unpublish", unpublish_admin_blog_post_path(post), method: :patch,
                      class: "text-xs text-gray-500 border border-gray-200 px-2 py-1 rounded-lg hover:bg-gray-50" %>
                <% end %>
                <%= button_to "Delete", admin_blog_post_path(post), method: :delete,
                    data: { turbo_confirm: "Delete '#{post.title}'?" },
                    class: "text-xs text-red-400 hover:text-red-600 border border-red-100 px-2 py-1 rounded-lg" %>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="4" class="px-5 py-12 text-center text-gray-400">
            No posts yet. <%= link_to "Write your first post", new_admin_blog_post_path, class: "text-rose-600 hover:underline" %>.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
