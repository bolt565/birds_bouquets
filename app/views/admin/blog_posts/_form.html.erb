<%= form_with model: [:admin, blog_post], html: { class: "space-y-5" } do |f| %>
  <% if blog_post.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% blog_post.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, required: true, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
  </div>

  <div>
    <%= f.label :slug, "Slug", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :slug, placeholder: "auto-generated", class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
  </div>

  <div>
    <%= f.label :excerpt, "Excerpt", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :excerpt, rows: 2, placeholder: "Short summary shown in listings...",
        class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300 resize-none" %>
  </div>

  <div>
    <%= f.label :body, "Content", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :body, rows: 16, placeholder: "Write your blog post here...",
        class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300 font-mono" %>
  </div>

  <div>
    <%= f.label :author_name, "Author", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :author_name, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
  </div>

  <details class="border border-gray-200 rounded-xl">
    <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-gray-700">SEO Settings</summary>
    <div class="p-4 space-y-4 border-t border-gray-100">
      <div>
        <%= f.label :meta_title, "Meta Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :meta_title, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
      </div>
      <div>
        <%= f.label :meta_description, "Meta Description", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :meta_description, rows: 2, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300 resize-none" %>
      </div>
    </div>
  </details>

  <div class="flex gap-3 pt-2">
    <%= f.submit blog_post.persisted? ? "Update Post" : "Save Draft",
        class: "px-6 py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_blog_posts_path, class: "px-6 py-3 border border-gray-200 text-gray-600 rounded-xl font-semibold hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
