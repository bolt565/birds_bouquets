<%= form_with model: [:admin, category], html: { class: "space-y-4" } do |f| %>
  <% if category.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% category.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :name, "Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
    <div>
      <%= f.label :slug, "Slug", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :slug, placeholder: "auto-generated", class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
  </div>

  <div>
    <%= f.label :description, "Description (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 2, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300 resize-none" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :position, "Position", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :position, min: 0, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
    <div class="flex items-end pb-3">
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <%= f.check_box :active, class: "text-rose-600 focus:ring-rose-300 rounded" %>
        Active (visible on site)
      </label>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit category.persisted? ? "Update Category" : "Create Category",
        class: "px-6 py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_categories_path, class: "px-6 py-3 border border-gray-200 text-gray-600 rounded-xl font-semibold hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
