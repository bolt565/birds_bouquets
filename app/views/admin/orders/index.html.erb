<% content_for :title, "Orders — Admin" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Orders</h1>
  <%= link_to "Export CSV", admin_orders_path(format: :csv, **params.permit(:status, :search, :from, :to).to_h), class: "inline-flex items-center px-4 py-2 border border-gray-200 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 mb-4 p-4">
  <%= form_with url: admin_orders_path, method: :get, data: { turbo: false } do |f| %>
    <div class="flex flex-wrap gap-3">
      <%= f.text_field :search, value: params[:search], placeholder: "Search by email or order #",
          class: "flex-1 min-w-48 border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
      <%= f.select :status, [["All Statuses", ""]] + Order::STATUSES.map { |s| [s.humanize, s] },
          { selected: params[:status] },
          class: "border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
      <%= f.date_field :from, value: params[:from], class: "border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
      <%= f.date_field :to, value: params[:to], class: "border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
      <%= f.submit "Filter", class: "px-4 py-2 bg-gray-700 text-white text-sm rounded-lg hover:bg-gray-800 cursor-pointer" %>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Order</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Customer</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Total</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @orders.any? %>
        <% @orders.each do |order| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3">
              <p class="font-semibold text-gray-900 text-xs"><%= order.order_number %></p>
              <p class="text-xs text-gray-400"><%= pluralize(order.order_items.size, "item") %></p>
            </td>
            <td class="px-5 py-3">
              <p class="text-gray-700"><%= order.email %></p>
              <p class="text-xs text-gray-400"><%= order.shipping_city %>, <%= order.shipping_state %></p>
            </td>
            <td class="px-5 py-3">
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold <%= order_status_color(order.status) %>">
                <%= order.status.humanize %>
              </span>
            </td>
            <td class="px-5 py-3 font-semibold text-gray-900"><%= format_cents(order.total_cents) %></td>
            <td class="px-5 py-3 text-gray-400 text-xs"><%= order.created_at.strftime("%b %d, %Y %H:%M") %></td>
            <td class="px-5 py-3">
              <%= link_to "View", admin_order_path(order), class: "text-xs text-rose-600 hover:underline font-medium" %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="6" class="px-5 py-12 text-center text-gray-400">No orders found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
