<% content_for :title, "Sign In — Birds Bouquets" %>

<div class="min-h-screen flex items-center justify-center -mt-8 py-8">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="<%= root_path %>" class="text-2xl font-bold text-rose-600">Birds Bouquets</a>
      <h2 class="text-2xl font-bold text-gray-900 mt-4">Welcome back</h2>
      <p class="text-gray-500 text-sm mt-1">Sign in to your account</p>
    </div>

    <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-sm">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
                class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
          </div>

          <div>
            <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password", required: true,
                class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center justify-between">
              <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                <%= f.check_box :remember_me, class: "text-rose-600 focus:ring-rose-300 rounded" %>
                Remember me
              </label>
              <%= link_to "Forgot your password?", new_user_password_path, class: "text-sm text-rose-600 hover:underline" %>
            </div>
          <% end %>

          <%= f.submit "Sign In", class: "w-full py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors cursor-pointer mt-2" %>
        </div>
      <% end %>

      <% if devise_mapping.omniauthable? %>
        <div class="my-6 flex items-center gap-4 text-sm text-gray-400">
          <div class="flex-1 h-px bg-gray-200"></div>
          <span>or</span>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>
        <%= link_to omniauth_authorize_path(resource_name, :google_oauth2), method: :post,
            class: "flex items-center justify-center gap-3 w-full py-3 border border-gray-200 rounded-xl hover:bg-gray-50 transition-colors text-sm font-medium text-gray-700",
            data: { turbo: false } do %>
          <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        <% end %>
      <% end %>
    </div>

    <p class="text-center text-sm text-gray-500 mt-6">
      Don't have an account? <%= link_to "Sign up", new_user_registration_path, class: "text-rose-600 font-medium hover:underline" %>
    </p>
  </div>
</div>
