<%= form_with model: [:account, address], html: { class: "space-y-4" } do |f| %>
  <% if address.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% address.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Full Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, required: true, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
  </div>

  <div>
    <%= f.label :line1, "Address Line 1", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :line1, required: true, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
  </div>

  <div>
    <%= f.label :line2, "Address Line 2 (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :line2, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :city, "City", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :city, required: true, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
    <div>
      <%= f.label :state, "State", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :state, required: true, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :zip, "ZIP Code", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :zip, required: true, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
    <div>
      <%= f.label :phone, "Phone (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.telephone_field :phone, class: "w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>
  </div>

  <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
    <%= f.check_box :default, class: "text-rose-600 focus:ring-rose-300 rounded" %>
    Set as default address
  </label>

  <div class="flex gap-3 pt-2">
    <%= f.submit address.persisted? ? "Update Address" : "Save Address",
        class: "px-6 py-3 bg-rose-600 text-white rounded-xl font-semibold hover:bg-rose-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", account_addresses_path, class: "px-6 py-3 border border-gray-200 text-gray-600 rounded-xl font-semibold hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
