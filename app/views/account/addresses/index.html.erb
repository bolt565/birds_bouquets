<% content_for :title, "My Addresses — Bird's Blossoms" %>

<div class="max-w-2xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">My Addresses</h1>
    <%= link_to "Add Address", new_account_address_path, class: "inline-flex items-center px-4 py-2 bg-rose-600 text-white rounded-lg text-sm font-medium hover:bg-rose-700 transition-colors" %>
  </div>

  <% if @addresses.any? %>
    <div class="space-y-4">
      <% @addresses.each do |addr| %>
        <div class="bg-white border border-gray-100 rounded-xl p-5">
          <div class="flex items-start justify-between">
            <div class="text-sm">
              <div class="flex items-center gap-2 mb-1">
                <p class="font-semibold text-gray-900"><%= addr.name %></p>
                <% if addr.default? %>
                  <span class="text-xs bg-rose-50 text-rose-600 px-2 py-0.5 rounded-full font-medium">Default</span>
                <% end %>
              </div>
              <p class="text-gray-600"><%= addr.line1 %><%= ", #{addr.line2}" if addr.line2.present? %></p>
              <p class="text-gray-600"><%= addr.city %>, <%= addr.state %> <%= addr.zip %></p>
              <% if addr.phone.present? %><p class="text-gray-400 text-xs mt-1"><%= addr.phone %></p><% end %>
            </div>
            <div class="flex items-center gap-2">
              <% unless addr.default? %>
                <%= button_to "Set Default", set_default_account_address_path(addr), method: :patch,
                    class: "text-xs text-gray-500 hover:text-rose-600 border border-gray-200 hover:border-rose-300 px-3 py-1.5 rounded-lg transition-colors" %>
              <% end %>
              <%= link_to "Edit", edit_account_address_path(addr), class: "text-xs text-gray-500 hover:text-rose-600 border border-gray-200 px-3 py-1.5 rounded-lg transition-colors" %>
              <%= button_to "Delete", account_address_path(addr), method: :delete,
                  data: { turbo_confirm: "Delete this address?" },
                  class: "text-xs text-red-400 hover:text-red-600 border border-red-100 hover:border-red-300 px-3 py-1.5 rounded-lg transition-colors" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-gray-50 rounded-xl">
      <p class="text-gray-400 mb-4">No saved addresses yet.</p>
      <%= link_to "Add Your First Address", new_account_address_path, class: "text-rose-600 hover:underline text-sm font-medium" %>
    </div>
  <% end %>

  <div class="mt-6">
    <%= link_to "← Back to Account", account_root_path, class: "text-sm text-gray-400 hover:text-gray-600" %>
  </div>
</div>
