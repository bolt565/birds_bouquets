<% content_for :title, "My Account — Bird's Blossoms" %>

<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">My Account</h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white border border-gray-100 rounded-xl p-5 text-center">
      <p class="text-3xl font-bold text-rose-600"><%= current_user.orders.count %></p>
      <p class="text-sm text-gray-500 mt-1">Total Orders</p>
    </div>
    <div class="bg-white border border-gray-100 rounded-xl p-5 text-center">
      <p class="text-3xl font-bold text-rose-600"><%= current_user.addresses.count %></p>
      <p class="text-sm text-gray-500 mt-1">Saved Addresses</p>
    </div>
    <div class="bg-white border border-gray-100 rounded-xl p-5 text-center">
      <p class="text-sm font-medium text-gray-900 truncate"><%= current_user.email %></p>
      <p class="text-sm text-gray-500 mt-1">Account Email</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Recent Orders</h2>
        <%= link_to "View All", orders_path, class: "text-sm text-rose-600 hover:underline" %>
      </div>
      <% if @recent_orders.any? %>
        <div class="space-y-3">
          <% @recent_orders.each do |order| %>
            <div class="bg-white border border-gray-100 rounded-xl p-4">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-semibold text-gray-900"><%= order.order_number %></p>
                  <p class="text-xs text-gray-400"><%= order.created_at.strftime("%b %d, %Y") %></p>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-xs px-2 py-1 rounded-full font-medium <%= order_status_color(order.status) %>">
                    <%= order.status.humanize %>
                  </span>
                  <%= link_to "View", order_path(order), class: "text-xs text-rose-600 hover:underline" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-gray-50 rounded-xl p-6 text-center text-sm text-gray-400">
          No orders yet. <%= link_to "Start shopping!", products_path, class: "text-rose-600 hover:underline" %>
        </div>
      <% end %>
    </div>

    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Addresses</h2>
        <%= link_to "Manage", account_addresses_path, class: "text-sm text-rose-600 hover:underline" %>
      </div>
      <% if @addresses.any? %>
        <div class="space-y-3">
          <% @addresses.first(2).each do |addr| %>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-sm">
              <div class="flex items-start justify-between">
                <div>
                  <p class="font-medium text-gray-900"><%= addr.name %></p>
                  <p class="text-gray-500"><%= addr.line1 %></p>
                  <p class="text-gray-500"><%= addr.city %>, <%= addr.state %> <%= addr.zip %></p>
                </div>
                <% if addr.default? %>
                  <span class="text-xs bg-rose-50 text-rose-600 px-2 py-0.5 rounded-full font-medium">Default</span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-gray-50 rounded-xl p-6 text-center text-sm text-gray-400">
          No saved addresses. <%= link_to "Add one", new_account_address_path, class: "text-rose-600 hover:underline" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-8 pt-6 border-t border-gray-100 flex items-center justify-between">
    <div>
      <p class="text-sm text-gray-500">Signed in as <strong><%= current_user.email %></strong></p>
      <p class="text-xs text-gray-400 mt-0.5">Member since <%= current_user.created_at.strftime("%B %Y") %></p>
    </div>
    <%= button_to "Sign Out", destroy_user_session_path, method: :delete,
        class: "text-sm text-red-500 hover:text-red-700 border border-red-200 hover:border-red-300 px-4 py-2 rounded-lg transition-colors" %>
  </div>
</div>
