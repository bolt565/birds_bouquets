<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= @seo_title.presence || "Birds Bouquets" %></title>
    <meta name="description" content="<%= @seo_description.presence || "Fresh flower delivery" %>">
    <% if @seo_canonical_url.present? %><link rel="canonical" href="<%= @seo_canonical_url %>"><% end %>
    <% if @seo_title.present? %>
    <meta property="og:title" content="<%= @seo_title %>">
    <meta property="og:description" content="<%= @seo_description %>">
    <meta property="og:url" content="<%= @seo_canonical_url %>">
    <meta property="og:image" content="<%= @seo_og_image %>">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <% end %>
    <%= render_structured_data %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <%= render "shared/nav" %>
    <div id="flash"><%= render "shared/flash" %></div>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
    <%= render "shared/footer" %>
  </body>
</html>
