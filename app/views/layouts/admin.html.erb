<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= @seo_title.presence || "Admin — Birds Bouquets" %></title>
    <meta name="robots" content="noindex, nofollow">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-100 text-gray-900 min-h-screen flex">
    <aside class="w-64 bg-gray-900 text-white min-h-screen flex flex-col">
      <div class="p-6 border-b border-gray-700">
        <a href="<%= admin_root_path %>" class="text-xl font-bold text-rose-400">🌸 Admin</a>
        <p class="text-xs text-gray-400 mt-1">Birds Bouquets</p>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <%= link_to "Dashboard", admin_root_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 hover:text-white transition-colors text-sm" %>
        <%= link_to "Stats", admin_stats_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 hover:text-white transition-colors text-sm" %>
        <%= link_to "Products", admin_products_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 hover:text-white transition-colors text-sm" %>
        <%= link_to "Categories", admin_categories_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 hover:text-white transition-colors text-sm" %>
        <%= link_to "Orders", admin_orders_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 hover:text-white transition-colors text-sm" %>
        <%= link_to "Customers", admin_customers_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 hover:text-white transition-colors text-sm" %>
        <%= link_to "Blog Posts", admin_blog_posts_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 hover:text-white transition-colors text-sm" %>
        <%= link_to "Job Queue", admin_good_job_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 hover:text-white transition-colors text-sm" %>
      </nav>
      <div class="p-4 border-t border-gray-700">
        <%= link_to "View Site", root_path, class: "block text-xs text-gray-400 hover:text-gray-200 mb-2" %>
        <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-xs text-gray-400 hover:text-gray-200" %>
      </div>
    </aside>

    <div class="flex-1 flex flex-col">
      <header class="bg-white border-b border-gray-200 px-6 py-4">
        <div id="flash"><%= render "shared/flash" %></div>
      </header>
      <main class="flex-1 p-6">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
