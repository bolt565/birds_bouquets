<div class="group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200">
  <div class="aspect-square overflow-hidden bg-gray-100">
    <% if product.primary_image&.image&.attached? %>
      <%= image_tag product.primary_image.image, alt: product.primary_image.alt_text,
            class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300",
            loading: "lazy" %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center text-gray-300">
        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
    <% end %>

    <% if product.sold_out? %>
      <div class="absolute top-3 left-3 bg-gray-900 text-white text-xs font-semibold px-2 py-1 rounded-full">
        Sold Out
      </div>
    <% elsif product.on_sale? %>
      <div class="absolute top-3 left-3 bg-rose-500 text-white text-xs font-semibold px-2 py-1 rounded-full">
        Sale
      </div>
    <% end %>
  </div>

  <div class="p-4">
    <h3 class="font-semibold text-gray-900 text-sm mb-1 leading-snug">
      <%= link_to product.name, product_path(product), class: "hover:text-rose-600 transition-colors" %>
    </h3>

    <div class="flex items-center gap-2 mb-3">
      <span class="text-rose-600 font-bold"><%= product.price_in_dollars %></span>
      <% if product.on_sale? %>
        <span class="text-gray-400 line-through text-sm"><%= product.compare_at_price_in_dollars %></span>
      <% end %>
    </div>

    <% if product.in_stock? %>
      <%= button_to "Add to Cart",
            add_item_cart_path,
            method: :post,
            params: { product_id: product.id, quantity: 1 },
            class: "w-full bg-rose-500 hover:bg-rose-600 text-white text-sm font-semibold py-2 px-4 rounded-xl transition-colors",
            data: { turbo_stream: true } %>
    <% else %>
      <button disabled class="w-full bg-gray-200 text-gray-400 text-sm font-semibold py-2 px-4 rounded-xl cursor-not-allowed">
        Sold Out
      </button>
    <% end %>
  </div>
</div>
