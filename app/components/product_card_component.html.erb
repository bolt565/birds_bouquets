<div class="group relative flex flex-col overflow-hidden rounded-[1.75rem] bg-shell ring-1 ring-linen hover:ring-sage transition">
  <div class="aspect-square overflow-hidden bg-linen">
    <% if product.primary_image&.image&.attached? %>
      <%= image_tag product.primary_image.image, alt: product.primary_image.alt_text,
            class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500",
            loading: "lazy" %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center text-sage-deep">
        <%= render "shared/sprig", classes: "w-32 h-22" %>
      </div>
    <% end %>

    <% if product.sold_out? %>
      <div class="absolute top-4 left-4 bg-ink text-cream text-xs px-3 py-1.5 rounded-full tracking-wide">
        Sold out
      </div>
    <% elsif product.on_sale? %>
      <div class="absolute top-4 left-4 bg-blush text-moss text-xs px-3 py-1.5 rounded-full tracking-wide">
        Sale
      </div>
    <% end %>
  </div>

  <div class="flex flex-col flex-1 p-5 text-center">
    <h3 class="font-display text-xl text-ink leading-snug">
      <%= link_to product.name, product_path(product), class: "hover:text-sage-deep transition-colors" %>
    </h3>

    <div class="flex items-center justify-center gap-2 mt-1 mb-4">
      <span class="text-moss font-medium"><%= product.price_in_dollars %></span>
      <% if product.on_sale? %>
        <span class="text-ink-soft line-through text-sm"><%= product.compare_at_price_in_dollars %></span>
      <% end %>
    </div>

    <% if product.in_stock? %>
      <%= button_to "Add to cart",
            add_item_cart_path,
            method: :post,
            params: { product_id: product.id, quantity: 1 },
            class: "w-full mt-auto bg-moss hover:bg-sage-deep text-cream text-sm tracking-wide py-2.5 px-4 rounded-full transition-colors",
            data: { turbo_stream: true } %>
    <% else %>
      <button disabled class="w-full mt-auto bg-linen text-ink-soft text-sm tracking-wide py-2.5 px-4 rounded-full cursor-not-allowed">
        Sold out
      </button>
    <% end %>
  </div>
</div>
