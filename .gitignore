# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development/test).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore assets that are generated.
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore master key for decrypting credentials and other encrypted files.
/config/master.key
/config/credentials/*.key

# Ignore node_modules
/node_modules

# Ignore yarn files
/yarn-error.log
yarn-debug.log*

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore test coverage
/coverage

# Ignore capybara/system test artifacts
/tmp/capybara

# Ignore database dumps
*.sql
*.dump
